{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://oktolabs.ai/schemas/okto-pulse/active-board.schema.json",
  "title": "Active Pulse board",
  "description": "Identifies which Pulse board is the active default for stage skills.",
  "type": "object",
  "additionalProperties": false,
  "required": ["board_id", "board_name", "set_at", "set_by"],
  "properties": {
    "board_id": {
      "type": "string",
      "format": "uuid",
      "pattern": "^[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{12}$",
      "description": "Pulse board uuid."
    },
    "board_name": {
      "type": "string",
      "minLength": 1,
      "description": "Human-readable board name (snapshot)."
    },
    "set_at": {
      "type": "string",
      "format": "date-time",
      "description": "ISO-8601 timestamp of when the board was made active."
    },
    "set_by": {
      "type": "string",
      "enum": ["setup", "board", "doctor"],
      "description": "Which skill/command set this value."
    }
  }
}
